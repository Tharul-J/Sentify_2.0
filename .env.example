# Vite Environment Variables
# Create a .env.local file (gitignored) and add your actual keys there

# Google Gemini API Keys (for sentiment analysis with auto-rotation)
# Get keys from: https://aistudio.google.com/app/apikey
# Add multiple keys for automatic rotation when quota is exceeded
VITE_GEMINI_API_KEY=your_gemini_api_key_here
VITE_GEMINI_API_KEY_2=your_second_gemini_api_key_here
VITE_GEMINI_API_KEY_3=your_third_gemini_api_key_here
VITE_GEMINI_API_KEY_4=your_fourth_gemini_api_key_here

# Backend API URL (default for local development)
VITE_API_BASE_URL=http://localhost:5000
